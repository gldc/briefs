---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[var(--color-rule)] mx-auto max-w-[78rem] px-6 py-10">
  <div class="flex flex-col sm:flex-row items-center sm:items-baseline justify-between gap-4 text-[0.85rem] text-[var(--color-mute)]">
    <div class="flex items-baseline gap-3">
      <span aria-hidden="true" class="fleuron">✦</span>
      <span>compiled by <span class="text-[var(--color-ink-soft)]">Athena</span> · daily at 07h00 ET</span>
    </div>
    <div class="flex items-baseline gap-5 font-[family-name:var(--font-mono)] text-[0.72rem] tracking-wider uppercase">
      <span>{year}</span>
      <a href="https://github.com/gldc/athena" class="no-underline hover:text-[var(--color-saffron-deep)]">source</a>
    </div>
  </div>
</footer>
